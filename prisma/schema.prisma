// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id // = Clerk user_id
  email         String
  parseCount    Int        @default(0)
  parseLimit    Int        @default(5)
  hasFullAccess Boolean    @default(false) // true after $4.99 purchase — unlocks parses + cover letter
  createdAt     DateTime   @default(now())
  analyses      Analysis[]
  purchases     Purchase[]
}

model Analysis {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  detectedRole     String?
  tier             String?
  contentScore     Int?
  atsScore         Int?
  roastHeadline    String?
  roastBody        String?
  dimensionScores  Json?
  hiringPrediction Json?
  redFlags         Json?
  strengths        Json?
  topPriority      String?
  // NO resumeText field -- ever
}

model Purchase {
  id              String   @id @default(uuid())
  userId          String?  // null = pending (buyer email didn't match any Clerk account at webhook time)
  user            User?    @relation(fields: [userId], references: [id])
  buyerEmail      String?  // email from Whop webhook — used to claim pending purchases
  type            String   // 'full_access' | 'parse_credits' | 'cover_letter'
  lsOrderId       String   @unique // Whop membership ID — prevents double-credit on retry
  creditsAdded    Int      @default(0)
  amountCents     Int
  createdAt       DateTime @default(now())
}
